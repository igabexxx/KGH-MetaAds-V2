# =============================================================
# KGH META ADS — MASTER ENVIRONMENT CONFIGURATION
# =============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ─── Database ─────────────────────────────────────────────
DB_PASSWORD=your_strong_password_here
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kgh_metads

# ─── Meta Marketing API ───────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_never_expiring_system_user_token
META_AD_ACCOUNT_ID=act_your_ad_account_id
META_PAGE_ID=your_facebook_page_id
META_API_VERSION=v19.0

# ─── N8N Configuration ────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=your_n8n_password
N8N_WEBHOOK_URL=https://your-domain.com/
N8N_ENCRYPTION_KEY=your_random_32_char_key_here

# ─── OpenClaw / LLM ───────────────────────────────────────
# Provider: "openai" | "anthropic" | "gemini"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your_llm_api_key_here

# ─── Messaging Platforms (Telegram & WhatsApp) ────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id_or_group
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_NUMBER_ID=your_whatsapp_number_id

# ─── Backend API ──────────────────────────────────────────
API_SECRET_KEY=your_secret_key_for_jwt
API_PORT=8000
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:8000

# ─── SocialChat Integration ─────────────────────────────────
SOCIALCHAT_API_KEY=your_socialchat_api_key
SOCIALCHAT_APP_ID=your_socialchat_app_id
SOCIALCHAT_SECRET_KEY=your_socialchat_secret_key
SOCIALCHAT_BASE_URL=https://api.socialchat.example.com

# ─── Security ─────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ─── Notification Settings ────────────────────────────────
NOTIFY_ON_NEW_LEAD=true
NOTIFY_ON_AUTOMATION_ACTION=true
NOTIFY_DAILY_REPORT=true
DAILY_REPORT_HOUR=8   # Hour in WIB (UTC+7)
